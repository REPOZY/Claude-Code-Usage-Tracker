{
    "name": "claude-counter-statusbar",
    "displayName": "Claude Counter Status Bar",
    "description": "Real-time Claude Code token usage, context window %, cache status, and session countdown in your status bar",
    "icon": "icon.png",
    "version": "1.0.0",
    "publisher": "REPOZY",
    "repository": {
      "type": "git",
      "url": "https://github.com/REPOZY/Claude-Code-Usage-Tracker.git"
    },
    "license": "MIT",
    "engines": {
      "vscode": "^1.85.0"
    },
    "categories": [
      "Other"
    ],
    "activationEvents": [
      "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
      "configuration": {
        "title": "Claude Counter Status Bar",
        "properties": {
          "claudeCounter.contextWindow": {
            "type": "number",
            "default": 200000,
            "description": "Context window size in tokens (adjust for your model/plan)"
          },
          "claudeCounter.refreshIntervalSeconds": {
            "type": "number",
            "default": 3,
            "minimum": 1,
            "description": "Status-bar refresh interval in seconds"
          }
        }
      }
    },
    "scripts": {
      "vscode:prepublish": "npm run compile",
      "compile": "tsc -p ./",
      "watch": "tsc -watch -p ./"
    },
    "dependencies": {
      "chokidar": "^3.6.0"
    },
    "devDependencies": {
      "@types/vscode": "^1.85.0",
      "@types/node": "^20",
      "typescript": "^5.3.0"
    }
  }